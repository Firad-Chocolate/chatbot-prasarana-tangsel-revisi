# Salin file ini menjadi .env lalu isi dengan kredensial ASLI kamu.
# JANGAN PERNAH commit file .env ke Git.

# --- Action endpoint (WAJIB, beda nilai tergantung platform) ---
# VPS (docker-compose, 2 container):
ACTION_ENDPOINT_URL=http://action-server:5055/webhook
# Railway (1 container gabungan) -- ganti baris di atas jadi:
# ACTION_ENDPOINT_URL=http://127.0.0.1:5055/webhook

# --- Database (Supabase PostgreSQL) ---
DB_HOST=xxxxxxxxxxxxx.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=ganti_dengan_password_baru_setelah_rotasi

# --- Cloudinary (untuk foto prasarana, jika dipakai di actions.py) ---
CLOUDINARY_CLOUD_NAME=xxxxxxxx
CLOUDINARY_API_KEY=xxxxxxxx
CLOUDINARY_API_SECRET=xxxxxxxx
